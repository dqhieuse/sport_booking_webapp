#!/bin/sh
set -e

BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
MAVEN_VERSION="${MAVEN_VERSION:-3.9.9}"
MAVEN_DIST_DIR="$BASE_DIR/.mvn/wrapper/dists/apache-maven-$MAVEN_VERSION"
MAVEN_HOME="$MAVEN_DIST_DIR/apache-maven-$MAVEN_VERSION"
MAVEN_ARCHIVE="$MAVEN_DIST_DIR/apache-maven-$MAVEN_VERSION-bin.tar.gz"
MAVEN_URL="https://archive.apache.org/dist/maven/maven-3/$MAVEN_VERSION/binaries/apache-maven-$MAVEN_VERSION-bin.tar.gz"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  mkdir -p "$MAVEN_DIST_DIR"
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_URL" -o "$MAVEN_ARCHIVE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$MAVEN_URL" -O "$MAVEN_ARCHIVE"
  else
    echo "Cannot download Maven: curl or wget is required." >&2
    exit 1
  fi
  tar -xzf "$MAVEN_ARCHIVE" -C "$MAVEN_DIST_DIR"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"
